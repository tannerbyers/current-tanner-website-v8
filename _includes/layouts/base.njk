<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {{ metadata.title }}{% else %}{{ metadata.title }} - AWS & Fullstack Development{% endif %}</title>
    <link rel="shortcut icon" type="image/jpg" href="/img/favicon.ico"/>
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#1b1b1b">
    <meta name="description" content="{{ description or metadata.description }}">
    <meta name="keywords" content="{{ metadata.keywords | join(', ') }}">
    <meta name="author" content="{{ metadata.author.name }}">
    <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{% if templateClass == 'tmpl-post' %}article{% else %}website{% endif %}">
    <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
    <meta property="og:title" content="{% if title %}{{ title }} - {{ metadata.title }}{% else %}{{ metadata.title }} - AWS & Fullstack Development{% endif %}">
    <meta property="og:description" content="{{ description or metadata.description }}">
    <meta property="og:image" content="{{ metadata.url }}{{ image or '/img/tanner.jpg' }}">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="{% if image %}summary_large_image{% else %}summary{% endif %}">
    <meta property="twitter:url" content="{{ metadata.url }}{{ page.url }}">
    <meta property="twitter:title" content="{% if title %}{{ title }} - {{ metadata.title }}{% else %}{{ metadata.title }} - AWS & Fullstack Development{% endif %}">
    <meta property="twitter:description" content="{{ description or metadata.description }}">
    <meta property="twitter:image" content="{{ metadata.url }}{{ image or '/img/tanner.jpg' }}">
    {%- if metadata.socialLinks.twitter %}
    <meta name="twitter:site" content="@{{ metadata.socialLinks.twitter }}">
    <meta name="twitter:creator" content="@{{ metadata.socialLinks.twitter }}">
    {%- endif %}
    
    {%- if templateClass == 'tmpl-post' %}
    <!-- Article-specific OG tags -->
    <meta property="article:published_time" content="{{ page.date | htmlDateString }}">
    <meta property="article:modified_time" content="{{ (lastModified or page.date) | htmlDateString }}">
    <meta property="article:author" content="{{ metadata.author.name }}">
    {%- for tag in tags | filterTagList %}
    <meta property="article:tag" content="{{ tag }}">
    {%- endfor %}
    {%- endif %}
    
    <!-- Preload critical resources -->
    <link rel="preload" href="{{ '/css/index.css' | url }}" as="style">
    <link rel="preload" href="/fonts/roboto-slab-400-latin.woff2" as="font" type="font/woff2" crossorigin>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/modern-normalize@3.0.1/modern-normalize.min.css">
    <link rel="stylesheet" href="{{ '/css/index.css' | cacheBust }}">
    <link rel="stylesheet" href="{{ '/css/prism-base16-monokai.dark.css' | cacheBust }}">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">
    <link rel="alternate" href="{{ metadata.jsonfeed.path | url }}" type="application/json" title="{{ metadata.title }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "{{ metadata.author.name }}",
      "url": "{{ metadata.url }}",
      "image": "{{ metadata.url }}/img/tanner.jpg",
      "jobTitle": "Software Engineer & Content Creator",
      "worksFor": {
        "@type": "Organization",
        "name": "Self"
      },
      "knowsAbout": ["AWS", "Software Development", "Cloud Infrastructure", "DevOps", "Full-Stack Development"],
      "email": "{{ metadata.author.email }}",
      "sameAs": [
        "{{ metadata.url }}",
        "{{ metadata.socialLinks.github }}",
        "{{ metadata.socialLinks.linkedin }}"
      ]
    }
    </script>
    
    {% include "components/article-structured-data.njk" %}
    
    <!-- WebSite structured data for sitelinks -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "{{ metadata.title }}",
      "url": "{{ metadata.url }}",
      "description": "{{ metadata.description }}",
      "author": {
        "@type": "Person",
        "name": "{{ metadata.author.name }}"
      }
    }
    </script>
    
    {%- if templateClass == 'tmpl-post' %}
    <!-- BreadcrumbList structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ metadata.url }}/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ metadata.url }}/posts/" },
        { "@type": "ListItem", "position": 3, "name": "{{ title }}" }
      ]
    }
    </script>
    {%- endif %}
    
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HB0Y5K6X23"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HB0Y5K6X23');
    </script>
    
  </head>
  <body>
    {%- if templateClass == 'tmpl-post' %}
    <div class="progress-bar" id="progress-bar" aria-hidden="true"></div>
    {%- endif %}
    <header>
      <h1 class="home"><a href="{{ '/' | url }}">{{ metadata.title }}</a></h1>
      <a class="skip-link" href="#content">Skip to content</a>
      {#- Read more about `eleventy-navigation` at https://www.11ty.dev/docs/plugins/navigation/ #}
      <nav class="nav">
        <ul class="nav-list">
          <li class="nav-item"><a href="{{ '/about/' | url }}" class="nav-link{% if page.url == '/about/' %} nav-item-active{% endif %}" {% if page.url == '/about/' %}aria-current="page"{% endif %}>About</a></li>
          <li class="nav-item"><a href="{{ '/posts/' | url }}" class="nav-link{% if page.url and page.url.startsWith('/posts/') %} nav-item-active{% endif %}" {% if page.url and page.url.startsWith('/posts/') %}aria-current="page"{% endif %}>Blog</a></li>
          <li class="nav-item"><a href="{{ '/speaking/' | url }}" class="nav-link{% if page.url == '/speaking/' %} nav-item-active{% endif %}" {% if page.url == '/speaking/' %}aria-current="page"{% endif %}>Speaking</a></li>
          <li class="nav-item"><a href="{{ metadata.feed.path | url }}" class="nav-link" title="RSS feed">RSS</a></li>
          <li class="nav-item nav-dropdown">
            <button class="nav-link nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">More</button>
            <ul class="nav-dropdown-menu" aria-label="More menu" role="menu" aria-hidden="true">
              <li role="none"><a role="menuitem" href="{{ '/search/' | url }}" class="nav-link">Search</a></li>
              <li role="none"><a role="menuitem" href="{{ '/newsletter/' | url }}" class="nav-link">Newsletter</a></li>
              <li role="none"><a role="menuitem" href="{{ '/contact-me/' | url }}" class="nav-link">Connect</a></li>
            </ul>
        </ul>
      </nav>
    </header>

    <main id="content" {% if templateClass %} class="{{ templateClass }}"{% endif %}>
      <div class="page-wrapper">
        <div class="page-side page-side-left" id="lava-left"></div>
        
        <div class="page-content" data-pagefind-body>
          {{ content | safe }}
        </div>
        
        <div class="page-side page-side-right" id="lava-right"></div>
      </div>
    </main>

    <footer>
      <div class="footer-subscribe">
        <form action="https://buttondown.email/api/emails/embed-subscribe/tannerbyers" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.email/tannerbyers', 'popupwindow')" class="footer-subscribe-form">
          <label for="bd-email-footer">Dev tips & AWS insights:</label>
          <div class="footer-subscribe-inputs">
            <input type="email" name="email" id="bd-email-footer" placeholder="your@email.com" required aria-label="Email address">
            <input type="submit" value="Subscribe">
          </div>
          <input type="hidden" value="1" name="embed">
        </form>
      </div>
      <div>{{ metadata.title}}</div>
      <div class="footer-social" style="margin: 0.5rem 0;">
        <a href="{{ metadata.socialLinks.github }}" aria-label="GitHub" rel="noopener noreferrer" target="_blank" style="margin: 0 0.5rem;"><i class="fab fa-github" style="font-size: 1.4rem;"></i></a>
        <a href="{{ metadata.socialLinks.linkedin }}" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank" style="margin: 0 0.5rem;"><i class="fab fa-linkedin" style="font-size: 1.4rem;"></i></a>
      </div>
      <div class="footer-text">
        © {% year %} {{ metadata.title }}, All rights reserved
      </div>
      <div class="footer-links" style="margin-top: 0.5rem; font-size: 0.8rem;">
        <a href="{{ '/privacy/' | url }}">Privacy Policy</a> |
        <a href="{{ '/terms/' | url }}">Terms of Service</a>
      </div>                         
    </footer>

    <a href="#" class="back-to-top" id="back-to-top" aria-label="Back to top" title="Back to top">&uarr;</a>

    <script src="{{ '/js/nav-dropdown.js' | cacheBust }}" defer></script>
    <script src="{{ '/js/external-links.js' | cacheBust }}" defer></script>
    <script>
      // Reading progress bar
      (function() {
        var bar = document.getElementById('progress-bar');
        if (!bar) return;
        window.addEventListener('scroll', function() {
          var h = document.documentElement;
          var pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
          bar.style.width = Math.min(pct, 100) + '%';
        }, { passive: true });
      })();
      // Back to top
      (function() {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function() {
          btn.classList.toggle('visible', window.scrollY > 400);
        }, { passive: true });
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
    <script>
      // Lava Lamp Toggle Functionality - Initialize early to ensure button is found
      function setupLavaToggle() {
        const toggle = document.getElementById('lava-toggle');
        const html = document.documentElement;
        
        if (!toggle) {
          console.warn('Lava toggle button not found');
          return;
        }
        
        // Check saved preference and apply on page load
        const savedPreference = localStorage.getItem('lava-lamps-enabled');
        const isEnabled = savedPreference !== 'false';
        
        if (!isEnabled) {
          html.classList.add('lava-off');
          toggle.classList.add('toggle-off');
        }
        
        // Add click handler
        toggle.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          const isCurrentlyOff = html.classList.contains('lava-off');
          
          if (isCurrentlyOff) {
            // Turn on
            html.classList.remove('lava-off');
            toggle.classList.remove('toggle-off');
            localStorage.setItem('lava-lamps-enabled', 'true');
          } else {
            // Turn off
            html.classList.add('lava-off');
            toggle.classList.add('toggle-off');
            localStorage.setItem('lava-lamps-enabled', 'false');
          }
        });
      }
      
      // Run as soon as DOM allows
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupLavaToggle);
      } else {
        setupLavaToggle();
      }
    </script>
    <script>
      const colors = [
        {
          gradient: 'linear-gradient(135deg, rgb(0, 225, 255), var(--yellowgreen), rgb(0, 225, 255))',
          glow: 'rgba(0, 225, 255, 0.4)'
        },
        {
          gradient: 'linear-gradient(45deg, #FF9900, #FFC300, #FFB700)',
          glow: 'rgba(255, 153, 0, 0.35)'
        },
        {
          gradient: 'linear-gradient(135deg, #9333ea, #a855f7, #c084fc)',
          glow: 'rgba(147, 51, 234, 0.4)'
        },
        {
          gradient: 'linear-gradient(45deg, #0080ff, #00d4ff, #0099ff)',
          glow: 'rgba(0, 152, 255, 0.35)'
        }
      ];

      const animationStyles = [
        'lava-float-1 15s ease-in-out infinite, lava-morph-1 8s ease-in-out infinite, pulse-glow 6s ease-in-out infinite',
        'lava-float-2 18s ease-in-out infinite 2s, lava-morph-2 9s ease-in-out infinite 1s, pulse-glow-orange 7s ease-in-out infinite',
        'lava-float-3 16s ease-in-out infinite 1s, lava-morph-1 9s ease-in-out infinite 2s, pulse-glow-purple 6.5s ease-in-out infinite 1s',
        'lava-float-4 17s ease-in-out infinite 3s, lava-morph-2 8.5s ease-in-out infinite 1.5s, pulse-glow-blue 7.5s ease-in-out infinite 0.5s'
      ];

      function createLavaLamps() {
        const leftContainer = document.getElementById('lava-left');
        const rightContainer = document.getElementById('lava-right');
        
        if (!leftContainer || !rightContainer) return;

        // Random number of blobs per side (3-5)
        const leftCount = Math.floor(Math.random() * 3) + 3;
        const rightCount = Math.floor(Math.random() * 3) + 3;

        // Create left side blobs
        for (let i = 0; i < leftCount; i++) {
          const blob = createBlob(i, 'left');
          leftContainer.appendChild(blob);
        }

        // Create right side blobs
        for (let i = 0; i < rightCount; i++) {
          const blob = createBlob(i, 'right');
          rightContainer.appendChild(blob);
        }
      }

      function createBlob(index, side) {
        const blob = document.createElement('div');
        blob.className = 'floating-shape';
        
        const colorIndex = index % colors.length;
        const color = colors[colorIndex];
        const animation = animationStyles[colorIndex];
        
        const sizes = [240, 260, 280];
        const size = sizes[Math.floor(Math.random() * sizes.length)];
        
        // Full page height randomization
        const viewportHeight = window.innerHeight + 400;
        const topPosition = Math.random() * viewportHeight - 100;
        
        const leftOffset = -180 + Math.random() * 100;
        const rightOffset = -160 + Math.random() * 100;
        
        const opacity = 0.18 + Math.random() * 0.08;
        
        blob.style.width = size + 'px';
        blob.style.height = size + 'px';
        blob.style.background = color.gradient;
        blob.style.backgroundSize = '200% 200%';
        blob.style.animation = animation;
        blob.style.opacity = opacity;
        blob.style.boxShadow = `0 0 ${40 + Math.random() * 30}px ${color.glow}`;
        
        if (side === 'left') {
          blob.style.top = topPosition + 'px';
          blob.style.left = leftOffset + 'px';
        } else {
          blob.style.top = topPosition + 'px';
          blob.style.right = rightOffset + 'px';
        }
        
        return blob;
      }

      // Initialize on page load
      document.addEventListener('DOMContentLoaded', createLavaLamps);
      createLavaLamps();
    </script>
  </body>
</html>
